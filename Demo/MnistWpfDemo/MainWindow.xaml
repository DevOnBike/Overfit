<Window x:Class="DevOnBike.Overfit.MnistWpfDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Beast MNIST Predictor" Height="450" Width="600"
        Background="#1e1e1e">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left side: drawing area -->
        <StackPanel Grid.Column="0" Width="280">
            <TextBlock Text="Draw a digit (0-9):" Foreground="White" FontSize="18" Margin="0,0,0,10" FontWeight="Bold" />

            <!-- InkCanvas: black background, thick white brush -->
            <Border BorderBrush="#3f3f46" BorderThickness="2" CornerRadius="4">
                <InkCanvas x:Name="DrawingCanvas" Width="280" Height="280" Background="Black"
                           MouseUp="DrawingCanvas_MouseUp">
                    <InkCanvas.DefaultDrawingAttributes>
                        <DrawingAttributes Color="White" Width="24" Height="24" FitToCurve="True" />
                    </InkCanvas.DefaultDrawingAttributes>
                </InkCanvas>
            </Border>

            <Button Content="Clear" Click="BtnClear_Click" Margin="0,15,0,0" Padding="10"
                    Background="#007acc" Foreground="White" FontSize="16" FontWeight="Bold" BorderThickness="0" />
        </StackPanel>

        <!-- Right side: prediction result -->
        <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="PREDICTION:" Foreground="#aaaaaa" FontSize="20" HorizontalAlignment="Center" />
            <TextBlock x:Name="TxtResult" Text="?" Foreground="#4caf50" FontSize="120" FontWeight="Black"
                       HorizontalAlignment="Center" Margin="0,-20,0,0" />
            <TextBlock x:Name="TxtStatus" Text="Waiting for a drawing..." Foreground="#888888" FontSize="14"
                       HorizontalAlignment="Center" Margin="0,20,0,0" />
        </StackPanel>
    </Grid>
</Window>
