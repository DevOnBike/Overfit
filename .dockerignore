# Keep the Docker build context small + reproducible. The AOT build only needs sources.
**/bin/
**/obj/
.git/
.github/
.vs/
.idea/
**/*.user
coverage/
TestResults/
# Exclude docs from the image context EXCEPT openapi.yaml, which Server.csproj embeds at compile time
# (GET /openapi.yaml + Swagger UI serve it from the self-contained binary). Without the negation the AOT
# publish fails: CS1566 "Could not find /src/docs/openapi.yaml".
docs/*
!docs/openapi.yaml
Demo/
UI/
# Never ship models / fixtures into the image — they are large and provided at runtime.
*.gguf
*.bin
*.safetensors
*.7z
**/test_fixtures/
*.wav
*.mp3
